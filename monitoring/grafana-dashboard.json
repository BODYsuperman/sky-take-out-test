{
  "dashboard": {
    "id": null,
    "title": "Sky Takeout Application Dashboard",
    "tags": ["spring-boot", "java", "microservice"],
    "timezone": "browser",
    "schemaVersion": 30,
    "version": 1,
    "refresh": "30s",
    "panels": [
      {
        "id": 1,
        "title": "JVM Memory Usage",
        "type": "graph",
        "datasource": "Prometheus",
        "targets": [
          {
            "expr": "jvm_memory_used_bytes{application=\"sky-takeout\"}",
            "legendFormat": "{{area}} - {{id}}"
          }
        ]
      },
      {
        "id": 2,
        "title": "HTTP Requests Rate",
        "type": "graph",
        "datasource": "Prometheus",
        "targets": [
          {
            "expr": "rate(http_server_requests_seconds_count{application=\"sky-takeout\"}[5m])",
            "legendFormat": "{{method}} {{uri}}"
          }
        ]
      },
      {
        "id": 3,
        "title": "Database Connection Pool",
        "type": "singlestat",
        "datasource": "Prometheus",
        "targets": [
          {
            "expr": "hikaricp_connections_active{application=\"sky-takeout\"}",
            "refId": "A"
          }
        ],
        "options": {
          "valueOptions": {
            "unit": "short",
            "stat": "avg"
          }
        }
      },
      {
        "id": 4,
        "title": "Error Rate",
        "type": "graph",
        "datasource": "Prometheus",
        "targets": [
          {
            "expr": "rate(http_server_requests_seconds_count{application=\"sky-takeout\", status=~\"5..\"}[5m])",
            "legendFormat": "5xx Errors"
          },
          {
            "expr": "rate(http_server_requests_seconds_count{application=\"sky-takeout\", status=~\"4..\"}[5m])",
            "legendFormat": "4xx Errors"
          }
        ]
      }
    ],
    "time": {
      "from": "now-6h",
      "to": "now"
    }
  }
}